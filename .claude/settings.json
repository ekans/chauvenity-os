{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun x gh-setup-hooks",
            "timeout": 120
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(bluebuild generate-iso:*)",
      "WebFetch(domain:blue-build.org)",
      "WebFetch(domain:github.com)"
    ],
    "deny": [],
    "ask": []
  }
}
